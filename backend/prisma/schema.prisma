generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())

  savedColleges SavedCollege[]
}

model College {
  id          Int      @id @default(autoincrement())
  name        String
  location    String
  fees        String
  rating      Float
  description String
  image       String
  createdAt   DateTime @default(now())

  courses     Course[]
  placements  Placement[]
  savedBy     SavedCollege[]
  cutoffs     Cutoff[]
}

model Course {
  id         Int      @id @default(autoincrement())
  name       String
  duration   String
  collegeId  Int

  college    College  @relation(fields: [collegeId], references: [id])
}

model Placement {
  id             Int      @id @default(autoincrement())
  placementRate  Float
  averagePackage String
  highestPackage String
  collegeId      Int

  college        College  @relation(fields: [collegeId], references: [id])
}

model SavedCollege {
  id         Int     @id @default(autoincrement())
  userId     Int
  collegeId  Int

  user       User    @relation(fields: [userId], references: [id])
  college    College @relation(fields: [collegeId], references: [id])

  createdAt  DateTime @default(now())
}

model Cutoff {
  id           Int      @id @default(autoincrement())
  exam         String
  branch       String
  openingRank  Int
  closingRank  Int
  collegeId    Int

  college      College @relation(fields: [collegeId], references: [id])
}
